generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AdminRole {
  ADMIN
  SUPER_ADMIN
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Admin {
  id String @id @default(uuid()) @db.Uuid

  name         String
  email        String    @unique
  password     String
  role         AdminRole @default(ADMIN)
  permissions  String[]  @default([]) // Store permissions as an array of strings
  lastEditedBy String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  // Primary Key
  id String @id @default(uuid()) @db.Uuid

  // Core fields
  name            String        @unique
  description     String        @db.Text()
  breadcrumb      String
  bannerImage     Json          @default("{\"imageUrl\": \"https://placehold.co/1440x500?text=Banner+Image\"}")
  path            String        @unique
  posterImage     Json          @default("{\"imageUrl\": \"https://placehold.co/600x600?text=Product+Image\"}")
  metaTitle       String
  metaDescription String
  canonicalUrl    String
  seoSchema       String?       @db.Text()
  lastEditedBy    String
  status          ContentStatus @default(PUBLISHED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[] @relation(name: "CategoryProducts")
  blogs    Blog[]    @relation(name: "CategoryBlogs")
}

model Product {
  id                String        @id @default(uuid()) @db.Uuid
  categoryId        String        @db.Uuid
  name              String
  description       String        @db.Text()
  breadcrumb        String
  bannerImage       Json          @default("{\"imageUrl\": \"https://placehold.co/1440x500?text=Banner+Image\"}")
  path              String        @unique
  posterImage       Json          @default("{\"imageUrl\": \"https://placehold.co/600x600?text=Product+Image\"}")
  firstImage        Json          @default("{\"imageUrl\": \"https://placehold.co/600x600?text=First+Image\"}")
  firstHeadinf      String
  firstDescription  String
  secondImage       Json          @default("{\"imageUrl\": \"https://placehold.co/600x600?text=Second+Image\"}")
  secondHeading     String
  secondDescription String
  productImages     Json[]        @default([])
  faq               Json[]        @default([])
  metaTitle         String?       @db.Text()
  metaDescription   String?       @db.Text()
  canonicalUrl      String?
  seoSchema         String?       @db.Text()
  lastEditedBy      String
  status            ContentStatus @default(PUBLISHED)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  category Category @relation(name: "CategoryProducts", fields: [categoryId], references: [id], onDelete: Restrict)
}

model Contact {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String
  phone     String
  whatsapp  String
  message   String
  createdAt DateTime @default(now())
}

model Blog {
  id          String @id @default(uuid()) @db.Uuid
  categoryId  String @db.Uuid
  title       String
  path        String @unique
  posterImage Json
  bannerImage Json
  content     String @db.Text()

  // SEO Fields
  metaTitle       String? @db.Text()
  metaDescription String? @db.Text()
  canonicalUrl    String?
  imageAltText    String?
  seoSchema       String? @db.Text()

  // Common Fields
  lastEditedBy String
  status       ContentStatus @default(PUBLISHED)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  category Category @relation(name: "CategoryBlogs", fields: [categoryId], references: [id], onDelete: Restrict)
}

model Appointment {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  email         String
  phone         String
  whatsapp      String?
  availableTime String
  emirate       String
  area          String
  message       String?  @db.Text()
  shutterTypes  String[]
  createdAt     DateTime @default(now())
}

model Testimonial {
  id          String @id @default(uuid()) @db.Uuid
  name        String
  designation String
  rating      Int    @default(5)
  description String @db.Text()

  lastEditedBy String
  status       ContentStatus @default(PUBLISHED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
